          },
          "query": "electricity = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"helen_electricity\")\n  |> filter(fn: (r) => r[\"_field\"] == \"electricity\")\n\nspot = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"helen_electricity\")\n  |> filter(fn: (r) => r[\"_field\"] == \"spot_price_vat\")\n\njoin(tables: {e: electricity, s: spot}, on: [\"_time\", \"gsrn\"])\n  |> map(fn: (r) => ({ _time: r._time, _value: (r._value_e * r._value_s) / 100.0 }))\n  |> sum()",
          "refId": "A"
