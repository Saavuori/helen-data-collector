      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${datasource}"
          },
          "query": "electricity = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"helen_electricity\")\n  |> filter(fn: (r) => r[\"_field\"] == \"electricity\")\n\nspot = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"helen_electricity\")\n  |> filter(fn: (r) => r[\"_field\"] == \"spot_price_vat\")\n\njoined = join(tables: {e: electricity, s: spot}, on: [\"_time\", \"gsrn\"])\n  |> map(fn: (r) => ({ _time: r._time, _value: r._value_e * r._value_s, _value_e: r._value_e }))\n\ntotal_kwh = joined |> sum(column: \"_value_e\") |> renameColumns(info: {\"_value_e\": \"_value\"})\ntotal_cost = joined |> sum(column: \"_value\")\n\njoin(tables: {c: total_cost, k: total_kwh}, on: [\"gsrn\"])\n  |> map(fn: (r) => ({ _value: r._value_c / r._value_k }))",
